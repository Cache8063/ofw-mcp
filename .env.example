OFW_USERNAME=your-email@example.com
OFW_PASSWORD=your-password

# Optional. Base64 of 32 random bytes (`openssl rand -base64 32`). When set,
# the local SQLite cache's content columns (message/draft subject+body,
# recipients, list payloads, attachment names/metadata) are encrypted at rest
# with AES-256-GCM. Keep this key OUTSIDE the cache dir (e.g. here / a secrets
# file you export) — a key stored next to the DB would be backed up alongside
# it and defeat the purpose. See README "Cache encryption".
# OFW_CACHE_KEY=

# Optional. Default is "none" (fail-safe) in this fork: no write tools are
# registered until you opt up. "drafts" = draft-level writes only; "all" =
# everything (send, calendar/expense/journal writes). OFW is a court-of-record
# platform — raise this deliberately.
# OFW_WRITE_MODE=none
